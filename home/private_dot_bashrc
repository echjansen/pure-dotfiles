#
# ~/.bashrc
#

# If not running interactively, don't do anything
[[ $- != *i* ]] && return

PS1='[\u@\h \W]\$ '

# Fonts
# setfont ter-v22b

# Aliases
alias ls='ls --color=auto'
alias grep='grep --color=auto'
alias dots=chezmoi
alias mg='mg -n'                     # micro emacs without littering

# Exports
# export $(envsubst < .env)
export EDITOR='emacs -nw'
export VISUAL=$EDITOR

