{{ if eq .chezmoi.os "linux" -}}

{{   $packages := list
       "git"
       "gitui"
       "make"
       "chezmoi"
       "ranger" -}}

{{   $desktop := list
       "hyprland"
       "hyprpaper"
       "hyprlang"
       "hypridle"
       "hyprlock"
       "hyprcursor"
       "xdg-desktop-portal-hyprland"
       "qt5-wayland"
       "qt6-wayland"
       "polkit-kde-agent"
       "cliphist"
       "foot"
       "emacs-wayland" -}}

{{   $sudo := "sudo " -}}
{{   if eq .chezmoi.username "root" -}}
{{     $sudo = "" -}}
{{   end -}}

#!/bin/bash

set -eufo pipefail

{{ $sudo }}pacman -Syu
{{ $sudo }}pacman -S --needed {{ $packages | join " " }}
{{ $sudo }}pacman -S --needed {{ $desktop | join " " }}

{{ end -}}
